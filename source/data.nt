import {
  core.dictionary {dictionary},
}

alias object(a) {
  dictionary(string, a)
}

data json {
| Null
| Bool(bool)
| Integer(int)
| Float(float)
| Text(string)
| Object(object(json))
| Array(list(json))
}

define insert(kvs: object(json), key: string, value: json) -> object(json) {
  let k = core.string.ord.as-ord;
  core.dictionary.make-insert(k)(kvs, key, value)
}

define lookup(kvs: &object(json), key: &string) -> ?&json {
  core.dictionary.make-lookup(core.string.ord.as-ord)(kvs, key)
}

define delete(k: &ord(string), kvs: object(json), key: string) -> object(json) {
  core.dictionary.delete(k, kvs, key)
}

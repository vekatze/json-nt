import {
  core::array,
  core::float.show {show-float},
  core::int.show {show-int},
  core::list {append, for-each, intercalate},
  core::list.show,
  core::string {join},
  _string.show {show-json-string},
  data {Array, Bool, Float, Integer, Null, Object, Text, json, object},
}

nominal {
  define show-json(j: json) -> string,
}

constant as-show: show(json) {
  Show{
    render := {
      (j) => {
        show-json(*j)
      }
    },
  }
}

constant list-json: show(list(json)) {
  core::list.show.as-show(as-show)
}

define _show-object(kvs: object(json)) -> string {
  let kvs = core::array.to-list(kvs);
  let kvs =
    for-each(kvs, (kv) => {
      let Pair(k, v) = kv;
      let k = show-json-string(k);
      let v = show-json(v);
      join(List::[k, *": ", v])
    });
  join(Cons(*"{", append(intercalate(kvs, *", "), List::[*"}"])))
}

define show-json(j: json) -> string {
  match j {
  | Null =>
    *"null"
  | Bool(b) =>
    if b {
      *"true"
    } else {
      *"false"
    }
  | Integer(i) =>
    show-int(i)
  | Float(x) =>
    show-float(x)
  | Text(x) =>
    show-json-string(x)
  | Object(kvs) =>
    _show-object(kvs)
  | Array(xs) =>
    let Show{render} = list-json;
    let xs = core::array.to-list(xs);
    pin xs = xs;
    render(xs)
  }
}

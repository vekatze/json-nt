import {
  core::string {pack},
  noa::control {Control-Success, control, control-bind},
  noa::gen {Gen, apply, gen, gen-bind, gen-map},
  noa::gen.float {gen-float},
  noa::gen.int {gen-int},
  noa::gen.list {gen-list},
  noa::suite {gen-kit},
  noa::suite.combinator {choose, scope},
  data {Array, Bool, Float, Integer, Null, Object, Text, empty-object, insert, json, json-array-from-list, object},
}

nominal {
  constant json-gen: gen(json),
}

constant _int-gen: gen(int) {
  gen-int(-1000000, 1000000, 0)
}

constant _float-gen: gen(float) {
  gen-float(-1000000.0, 1000000.0, 0.0)
}

constant _rune-gen: gen(rune) {
  gen-map(gen-int(0, 126, 0), (code) => {
    magic cast(int, rune, code)
  })
}

define _string-gen() -> gen(string) {
  gen-map(gen-list(_rune-gen), (rs) => {
    pin rs = rs;
    pack(rs)
  })
}

define _object-entry-gen() -> gen(pair(string, json)) {
  gen-bind(_string-gen(), (key) => {
    gen-map(json-gen, (value) => {
      Pair(key, value)
    })
  })
}

define _object-from-entries(entries: list(pair(string, json))) -> object(json) {
  let f =
    define loop(entries: list(pair(string, json)), acc: object(json)) -> object(json) {
      match entries {
      | Nil =>
        acc
      | Cons(entry, rest) =>
        let Pair(key, value) = entry;
        loop(rest, insert(acc, key, value))
      }
    };
  f(entries, empty-object())
}

define _generate-json(k: &gen-kit) ->> control(json, json) {
  scope<json, json>(k, (k) =>> {
    with control-bind {
      bind tag = choose<json>(k, 7);
      match tag {
      | 0 =>
        Control-Success(Null)
      | 1 =>
        bind b = choose<json>(k, 2);
        Control-Success(Bool(eq-int(b, 1)))
      | 2 =>
        bind i = apply(_int-gen, k);
        Control-Success(Integer(i))
      | 3 =>
        bind x = apply(_float-gen, k);
        Control-Success(Float(x))
      | 4 =>
        bind t = apply(_string-gen(), k);
        Control-Success(Text(t))
      | 5 =>
        bind xs = apply(gen-list(json-gen), k);
        Control-Success(Array(json-array-from-list(xs)))
      | _ =>
        bind entries = apply(gen-list(_object-entry-gen()), k);
        Control-Success(Object(_object-from-entries(entries)))
      }
    }
  })
}

constant json-gen: gen(json) {
  Gen(
    <r>(k: &gen-kit) =>> {
      scope<r, json>(k, (k) =>> {
        _generate-json(k)
      })
    },
  )
}

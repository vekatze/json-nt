import {
  core.eq.generic {eq-data},
  noa.check {check},
  noa.gen.string {string-gen},
  noa.noa-kit {make-default-noa-kit},
  noa.test {test},
  this._string.parse {parse-json-string},
  this._string.show {show-json-string-without-quote},
  this.data {json},
  this.gen {json-gen},
  this.parse {parse-json},
  this.show {show-json},
  zonk.parse {make-zonk-kit},
}

define main() -> unit {
  pin k = make-default-noa-kit();
  test(
    k,
    "JSON Unicode escape accepts four hexadecimal digits without a 0x prefix",
    () => {
      match parse-json-string("\\u001e") {
      | Left(_) =>
        False
      | Right(t) =>
        pin t = t;
        pin q = show-json-string-without-quote(t);
        eq-string(q, "\\u001e")
      }
    },
  );
  check::(
    k,
    "∀ (t: string). quote(parse(quote(t))) == quote(t)",
    string-gen,
    (t: string) => {
      pin t = t;
      pin t-without-quote = show-json-string-without-quote(t);
      match parse-json-string(t-without-quote) {
      | Left(_) =>
        False
      | Right(t2) =>
        pin t2 = t2;
        pin t3 = show-json-string-without-quote(t2);
        eq-string(t-without-quote, t3)
      }
    },
  );
  check::(
    k,
    "∀ (j: json). show(parse(show(j))) == show(j)",
    json-gen,
    (j: json) => {
      pin json-txt = show-json(j);
      pin k = make-zonk-kit(*json-txt, Unit);
      match parse-json(k) {
      | Right(j) =>
        pin new-json-txt = show-json(j);
        eq-data::(json-txt, new-json-txt)
      | Left(_) =>
        False
      }
    },
  )
}

define zen() -> unit {
  pin k = make-zonk-kit(*" {\"key\" : 1234}", Unit);
  match parse-json(k) {
  | Right(j) =>
    pin j = show-json(j);
    print("ok: ");
    print-line(j);
  | Left(_) =>
    print("unreachable")
  }
}
